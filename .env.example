# Origin of the product app (auth, dashboard) that this marketing site links to.
# In production, e.g. https://app.klovered.io — leave blank for local preview.
NEXT_PUBLIC_APP_URL=

# Contact form delivery (Resend). Required for /api/contact to send.
RESEND_API_KEY=
# Where submissions are delivered.
CONTACT_TO_EMAIL=khalifa.villaflor1@gmail.com
# From address. Until a domain is verified in Resend, use the shared sender
# below — it can only deliver to the Resend account owner's address.
RESEND_FROM=Klovered <onboarding@resend.dev>
